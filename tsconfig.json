{
    "compilerOptions": {
        "target": "ES6",
        "module": "nodenext",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "baseUrl": "./src",
        "paths": {
            "@/*": ["*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
